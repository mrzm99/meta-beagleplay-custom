From a816ed753f47c7d6d345c3f2651068bfb5c66d10 Mon Sep 17 00:00:00 2001
From: mrzm99 <mrzm.cpp@gmail.com>
Date: Sat, 21 Feb 2026 23:08:37 +0900
Subject: [PATCH] arm: dts: ti: add w25q128 spi flash to mikrobus

---
 dts/upstream/src/arm64/ti/k3-am625-beagleplay.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/dts/upstream/src/arm64/ti/k3-am625-beagleplay.dts b/dts/upstream/src/arm64/ti/k3-am625-beagleplay.dts
index 72b09f9c69d..d9c7ef6e409 100644
--- a/dts/upstream/src/arm64/ti/k3-am625-beagleplay.dts
+++ b/dts/upstream/src/arm64/ti/k3-am625-beagleplay.dts
@@ -825,9 +825,17 @@
 };
 
 &main_spi2 {
+    #address-cells = <1>;
+    #size-cells = <0>;
 	pinctrl-names = "default";
 	pinctrl-0 = <&mikrobus_spi_pins_default>;
 	status = "okay";
+
+    flash@0 {
+        compatible = "winbond,w25q128", "jedec,spi-nor";
+        reg = <0>;
+        spi-max-frequency = <1000000>;
+    };
 };
 
 &sdhci0 {
-- 
2.43.0

